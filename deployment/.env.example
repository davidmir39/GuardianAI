# =====================================================================
# Variables de entorno opcionales para docker compose.
# Cree una copia de este fichero como `.env` y modifique lo necesario.
# Si no se define, se usaran los valores por defecto del docker-compose.
# =====================================================================

# ---------------- API ---------------------------------------------------
API_PORT=8000              # Puerto expuesto en el host para la API.
UVICORN_WORKERS=1          # Procesos uvicorn (subir si hay carga concurrente).
DEFAULT_THRESHOLD=0.5      # Fallback si los metadatos no incluyen umbral.
# THRESHOLD_OVERRIDE=0.92  # Descomentar para forzar un umbral fijo.

# ---------------- Entrenamiento ----------------------------------------
SEARCH_MODE=quick          # 'quick' (usa Hito 3) o 'full' (RandomizedSearchCV).
SEARCH_N_ITER=30
SEARCH_CV_FOLDS=3
RANDOM_STATE=42
N_JOBS=-1
